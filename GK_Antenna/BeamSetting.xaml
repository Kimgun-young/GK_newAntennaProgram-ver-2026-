<Page x:Class="GK_Antenna.BeamSetting"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GK_Antenna"
        mc:Ignorable="d"
       d:DesignHeight="1080"
        d:DesignWidth="1920"
        Background="#2C3E50">

    <Grid>
        <Grid Margin="20">
            <UniformGrid Rows="1" Columns="5" Margin="0,80,0,0"></UniformGrid>
        </Grid>

        <Canvas VerticalAlignment="Top">
            <Border x:Name="TopBar"
        Background="#2C3E50"
        Height="99"
        Width="1920" 
        Canvas.Left="-20" 
        Canvas.Top="-20"
        MouseEnter="TopBar_MouseEnter"
        MouseLeave="TopBar_MouseLeave">
                <Image Source="/Resources/logos/white_GK_logo.png"
           Stretch="Uniform"
           Margin="38,1,1560,-11"/>
            </Border>

            <TextBlock x:Name="TopBarTrackingDashboard" Text="Tracking Dashboard" Foreground="White" FontSize="36" Canvas.Left="440" Canvas.Top="4" IsHitTestVisible="False" Height="68" Width="340"/>
            <TextBlock x:Name="TopBarSetting" Text="Setting" Foreground="White" FontSize="36" Canvas.Left="958" Canvas.Top="2" IsHitTestVisible="False" Height="68" Width="116"/>
            <TextBlock x:Name="TopBarMap" Text="Map" Foreground="White" FontSize="36" Canvas.Left="1317" Canvas.Top="1" IsHitTestVisible="False" Height="68" Width="116"/>
            <TextBlock x:Name="TopBarMapAbout" Text="About" Foreground="White" FontSize="36" Canvas.Left="1662" Canvas.Top="1" IsHitTestVisible="False" Height="68" Width="116"/>

            <Border x:Name="DropBar"
            Background="White"
            Height="160"
            Width="1920"
            Canvas.Left="-20"
            Canvas.Top="79" 
            Visibility="Collapsed"
            MouseEnter="DropBar_MouseEnter"
            MouseLeave="DropBar_MouseLeave">

                <Canvas>
                    <StackPanel Canvas.Left="600" Canvas.Top="20">
                        <TextBlock x:Name="StatusText"  Text="Status" Foreground="Black" FontSize="24" Margin="0,10" Cursor="Hand" MouseLeftButtonDown="StatusText_Click"/>
                    </StackPanel>

                    <StackPanel Canvas.Left="958" Canvas.Top="20">
                        <TextBlock x:Name="BeamSettingText" Text="Beam Setting" Foreground="Black" FontSize="24" Margin="0,10" Cursor="Hand" MouseLeftButtonDown="BeamSettingText_Click"/>
                        <TextBlock Text="IP Setting" Foreground="Black" FontSize="24" Margin="0,10" Cursor="Hand"/>
                    </StackPanel>

                    <StackPanel Canvas.Left="1340" Canvas.Top="20">
                        <TextBlock Text="Map" Foreground="Black" FontSize="24" Margin="0,10" Cursor="Hand"/>
                    </StackPanel>

                    <StackPanel Canvas.Left="1662" Canvas.Top="20">
                        <TextBlock Text="Company Info" Foreground="Black" FontSize="24" Margin="0,10" Cursor="Hand"/>
                    </StackPanel>
                </Canvas>
            </Border>
        </Canvas>
    </Grid>

</Page>
