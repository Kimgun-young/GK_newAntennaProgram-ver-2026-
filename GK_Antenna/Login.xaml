<Page x:Class="GK_Antenna.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="1080"
      d:DesignWidth="1920"
      Background="#D3D3D3">

    <Grid>
        <Border Background="White"
                Padding="40"
                CornerRadius="10"
                Width="556"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Height="560">

            <StackPanel>

                <Image Source="/Resources/logos/GK_logo.png"
                       Height="126"
                       Width="330"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

                <Grid Margin="0,10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Company Code:"
                               VerticalAlignment="Center"
                               FontSize="18"/>

                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             Height="35"
                             Padding="5"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Antenna IP:"
                               VerticalAlignment="Center"
                               Margin="0,30,0,0"
                               FontSize="18"/>

                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Height="35"
                             Padding="5"
                             Margin="0,30,0,0"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="Antenna Port:"
                               VerticalAlignment="Center"
                               Margin="0,30,0,0"
                               FontSize="18"/>

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Height="35"
                             Padding="5"
                             Margin="0,30,0,0"/>
                </Grid>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,40,0,0">

                    <Button Content="OK"
                            Width="120"
                            Height="40"
                            Margin="0,0,20,0"
                            Background="#0078D7"
                            Foreground="White"
                            FontWeight="Bold"
                            Click="OkButton_Click"/>

                    <Button Content="Cancel"
                            Width="120"
                            Height="40"
                            Background="#D83B01"
                            Foreground="White"
                            FontWeight="Bold"
                            Click="CancelButton_Click"/>

                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>