<Page x:Class="GK_Antenna.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="1080"
      d:DesignWidth="1920"
      Background="#D3D3D3">

    <Viewbox Stretch="Uniform">
        <Grid Width="1920" Height="1080">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0*"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Background="White"
                        Padding="40"
                        CornerRadius="10"
                        Width="556"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Height="612" Grid.Column="1" Margin="672,0,0,0">

                    <StackPanel>
                        <Image Source="/Resources/logos/GK_logo.png"
                               Height="146"
                               Width="304"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>

                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       VerticalAlignment="Top"
                                       FontSize="24"
                                       Text="Company Code :" Margin="-19,0,307,0" Grid.ColumnSpan="2" />

                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Height="35"
                                     x:Name="CompanyCodeBox" Width="300" Margin="24,1,2,109" TextChanged="CompanyCodeBox_TextChanged" BorderThickness="2,2,2,2" FontSize="20" Grid.RowSpan="4"/>

                            <Label Grid.Row="3" Grid.Column="1"
                                   x:Name="CompanyCodemsg"
                                   Foreground="Red" Margin="26,1,53,77" FontSize="20"/>

                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       VerticalAlignment="Top"
                                       FontSize="24"
                                       Text="Antenna IP :" Margin="28,79,315,0" Grid.ColumnSpan="2" />

                            <TextBox Grid.Row="3" Grid.Column="1"
                                     Height="35"
                                     x:Name="AntennaIpBox" Margin="24,81,2,-4" FontSize="20" Width="300" TextChanged="IPTextBox_TextChanged" BorderThickness="2,2,2,2"/>

                            <Label Grid.Row="3" Grid.Column="1"
                                   x:Name="ipmsg"
                                   Foreground="Red" Margin="26,116,-12,-42" FontSize="20"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button 
                    Content="OK"
                    Margin="815,0,975,335"
                    Background="#0078D7"
                    Foreground="White"
                    FontWeight="Bold"
                    x:Name="OkButton"
                    VerticalAlignment="Bottom"
                    Click="OkButton_Click" Grid.Column="1" Height="45" FontSize="20"/>

                <Button 
                    Content="Cancel"
                    Background="#D83B01"
                    Foreground="White"
                    FontWeight="Bold"
                    x:Name="CacelButton"
                    VerticalAlignment="Bottom"
                    Click="CancelButton_Click" Margin="975,0,815,335" RenderTransformOrigin="1.4,1.25" Grid.Column="1" Height="45" FontSize="20"/>

                <Grid x:Name="alert"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top" 
                      Margin="794,82,0,0"
                      Width="312" 
                      Height="80"
                      Visibility="Collapsed" Grid.Column="1">

                    <Rectangle Fill="White"
                               RadiusX="15"
                               RadiusY="15"
                               Stroke="#EEEEEE"
                               StrokeThickness="1" Margin="-29,0,-71,0"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image x:Name="alertImg"
                               Width="50"
                               Height="50"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Source="/Resources/Images/ant-design--check-circle-filled (1).png" Margin="-10,0,0,0"/>

                        <Label x:Name="alertText"
                                   Content="Connection Success"
                                   VerticalAlignment="Center"
                                   FontFamily="#MilSpec33558"
                                   FontSize="36" 
                                   Foreground="#333333" Margin="45,0,-64,0" Grid.ColumnSpan="2"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Viewbox>
</Page>