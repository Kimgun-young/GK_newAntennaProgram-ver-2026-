         Margin="86,169,0,0" Grid.Row="2" Grid.ColumnSpan="2">

            <Border Background="#001F3F" CornerRadius="12" Padding="30" Width="519" Height="398">
                <StackPanel Width="500">
                    <Grid Width="450" Height="350" HorizontalAlignment="Center">
                        <Canvas x:Name="SpeedometerCanvas" Margin="-30,-12,-78,-36"
                        Loaded="SpeedometerCanvas_Loaded">

                            <!-- 바늘 -->
                            <Rectangle x:Name="NeedleRect"
                               Width="4" Height="140" Fill="Red"
                               Canvas.Left="223" Canvas.Top="80"
                               RenderTransformOrigin="0.5,1.0">
                                <Rectangle.RenderTransform>
                                    <RotateTransform x:Name="NeedleRotation" Angle="-120"/>
                                </Rectangle.RenderTransform>
                            </Rectangle>

                            <!-- 중심 원 -->
                            <Ellipse Width="24" Height="24" Fill="White"
                             Canvas.Left="213" Canvas.Top="208"/>

                            <!-- 속도 텍스트 -->
