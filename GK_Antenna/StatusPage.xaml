               Width="110"/>


            <Canvas x:Name="EsNoLevelCanvas" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Top" 
                Margin="0,45,0,0" 
                Width="60" 
                Height="360">

                <Rectangle x:Name="EsNoTubePath" 
                   Fill="Transparent"
                   Stroke="White" 
                   StrokeThickness="3" 
                   Width="44" 
                   Height="356"
