           Canvas.Left="172" Canvas.Top="465" HorizontalAlignment="Left" VerticalAlignment="Center" Width="117" TextAlignment="Center" RenderTransformOrigin="0.487,0.304"/>

                <!-- YAW 값 -->
                <TextBlock x:Name="YawValueText" Text="0.0°" Foreground="White" FontSize="24"
           Canvas.Left="309" Canvas.Top="465" HorizontalAlignment="Left" VerticalAlignment="Center" Width="140" TextAlignment="Center" RenderTransformOrigin="0.424,0.467"/>

            </Canvas>
        </Viewbox>

