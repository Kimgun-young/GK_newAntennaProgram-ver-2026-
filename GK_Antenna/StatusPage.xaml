    <Grid Margin="20">

        <!-- 🔹 상태 박스 영역 -->
        <UniformGrid Rows="1" Columns="5" Margin="0,0,0,20">

            <!-- Connection -->
            <StackPanel>
                <TextBlock Text="Connection" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                <Border x:Name="ConnectionBox" Height="150" Background="#5A78C9" Margin="5">
                    <TextBlock x:Name="ConnectionText"
                               Text="N/A"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Temperature -->
            <StackPanel>
                <TextBlock Text="Temperature (°C)" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                <Border x:Name="TemperatureBox" Height="150" Background="#5A78C9" Margin="5">
                    <TextBlock x:Name="TemperatureText"
                               Text="N/A"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Voltage -->
            <StackPanel>
                <TextBlock Text="Voltage (V)" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                <Border x:Name="VoltageBox" Height="150" Background="#5A78C9" Margin="5">
                    <TextBlock x:Name="VoltageText"
                               Text="N/A"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Current -->
            <StackPanel>
                <TextBlock Text="Current (A)" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                <Border x:Name="CurrentBox" Height="150" Background="#5A78C9" Margin="5">
                    <TextBlock x:Name="CurrentText"
                               Text="N/A"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- EsNo -->
            <StackPanel>
                <TextBlock Text="Es/No (dBm)" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                <Border x:Name="EsNoBox" Height="150" Background="#5A78C9" Margin="5">
                    <TextBlock x:Name="EsNoText"
                               Text="N/A"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

