        <GroupBox x:Name="openAmip" 
          Header="OpenAMIP Log" 
          HorizontalAlignment="Left"
          Width="708"
          Margin="28,597,0,29"
          FontFamily="/Resources/fonts/#MilSpec33558"
          FontSize="20" 
          Foreground="White" Grid.Row="2" Grid.ColumnSpan="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ListBox x:Name="openlistbox" 
                 Foreground="White"        
                 FontFamily="/Resources/fonts/#MilSpec33558"        
                 Grid.Row="1"
                 Margin="5,0,0,5" 
                 FontSize="16"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto" 
                 ScrollViewer.VerticalScrollBarVisibility="Visible"
                 Background="#001F3F">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="NoWrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>

