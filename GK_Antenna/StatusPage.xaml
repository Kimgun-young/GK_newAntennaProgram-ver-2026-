<Page x:Class="GK_Antenna.StatusPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="1080"
      d:DesignWidth="1920"
      Background="#2C3E50">

    <Grid Margin="20">

        <!-- 🔹 상태 박스 영역 -->
        <UniformGrid Rows="1" Columns="5" Margin="0,0,0,20">

            <!-- Connection -->
            <StackPanel>
                <TextBlock Text="Connection" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                <Border x:Name="ConnectionBox" Height="150" Background="#5A78C9" Margin="5">
                    <TextBlock x:Name="ConnectionText"
                               Text="N/A"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Temperature -->
            <StackPanel>
                <TextBlock Text="Temperature (°C)" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                <Border x:Name="TemperatureBox" Height="150" Background="#5A78C9" Margin="5">
                    <TextBlock x:Name="TemperatureText"
                               Text="N/A"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Voltage -->
            <StackPanel>
                <TextBlock Text="Voltage (V)" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                <Border x:Name="VoltageBox" Height="150" Background="#5A78C9" Margin="5">
                    <TextBlock x:Name="VoltageText"
                               Text="N/A"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Current -->
            <StackPanel>
                <TextBlock Text="Current (A)" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                <Border x:Name="CurrentBox" Height="150" Background="#5A78C9" Margin="5">
                    <TextBlock x:Name="CurrentText"
                               Text="N/A"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- EsNo -->
            <StackPanel>
                <TextBlock Text="Es/No (dBm)" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                <Border x:Name="EsNoBox" Height="150" Background="#5A78C9" Margin="5">
                    <TextBlock x:Name="EsNoText"
                               Text="N/A"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

        </UniformGrid>

        <!-- 🔹 나침반 영역 -->
        <Canvas x:Name="CompassCanvas"
                Width="400"
                Height="400"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="738,307,0,0"/>

        <TextBlock x:Name="AzimuthText"
           Text="Azimuth: 0°"
           Foreground="White"
           FontSize="24"
           FontWeight="Bold"
           HorizontalAlignment="Center"
           VerticalAlignment="Top"
           Margin="0,776,0,0"/>

        <Viewbox x:Name="AttitudeIndicatorGroup" Width="450" Height="450" 
         HorizontalAlignment="Left" VerticalAlignment="Top" Margin="1207,302,0,0">
            <Canvas Width="450" Height="450">

                <Grid Canvas.Left="25" Canvas.Top="25" Width="400" Height="400">
                    <Ellipse Stroke="Black" StrokeThickness="1" Fill="#1A1A1A"/>
                    <Grid Margin="5">
                        <Grid.Clip>
                            <EllipseGeometry Center="195,195" RadiusX="195" RadiusY="195"/>
                        </Grid.Clip>
                        <Rectangle Fill="#2196F3" Height="195" VerticalAlignment="Top"/>
                        <Rectangle Fill="#5D4037" Height="195" VerticalAlignment="Bottom"/>
                    </Grid>
                </Grid>

                <Polygon Points="-12,0 12,0 0,45" Fill="White" 
                 Canvas.Left="225" Canvas.Top="30"/>

                <Canvas IsHitTestVisible="False" Width="450" Height="450">
                    <Rectangle Fill="White" Width="2" Height="15" Canvas.Left="224" Canvas.Top="60" RenderTransformOrigin="0.5,11.0">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="-10"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                    <Rectangle Fill="White" Width="2" Height="15" Canvas.Left="224" Canvas.Top="60" RenderTransformOrigin="0.5,11.0">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="-20"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                    <Rectangle Fill="White" Width="2" Height="15" Canvas.Left="224" Canvas.Top="60" RenderTransformOrigin="0.5,11.0">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="-45"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                    <Rectangle Fill="White" Width="2" Height="15" Canvas.Left="224" Canvas.Top="60" RenderTransformOrigin="0.5,11.0">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="10"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                    <Rectangle Fill="White" Width="2" Height="15" Canvas.Left="224" Canvas.Top="60" RenderTransformOrigin="0.5,11.0">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="20"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                    <Rectangle Fill="White" Width="2" Height="15" Canvas.Left="224" Canvas.Top="60" RenderTransformOrigin="0.5,11.0">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="45"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>

                    <Rectangle Fill="White" Width="4" Height="45" Canvas.Left="223" Canvas.Top="30" RenderTransformOrigin="0.5,4.33">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="-30"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                    <Rectangle Fill="White" Width="4" Height="45" Canvas.Left="223" Canvas.Top="30" RenderTransformOrigin="0.5,4.33">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="-60"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                    <Rectangle Fill="White" Width="4" Height="45" Canvas.Left="223" Canvas.Top="30" RenderTransformOrigin="0.5,4.33">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="-90"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                    <Rectangle Fill="White" Width="4" Height="45" Canvas.Left="223" Canvas.Top="30" RenderTransformOrigin="0.5,4.33">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="30"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                    <Rectangle Fill="White" Width="4" Height="45" Canvas.Left="223" Canvas.Top="30" RenderTransformOrigin="0.5,4.33">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="60"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                    <Rectangle Fill="White" Width="4" Height="45" Canvas.Left="223" Canvas.Top="30" RenderTransformOrigin="0.5,4.33">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="90"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>

                    <TextBlock Text="10" Foreground="White" FontSize="16" FontWeight="Bold" Canvas.Left="249" Canvas.Top="6"/>
                    <TextBlock Text="20" Foreground="White" FontSize="16" FontWeight="Bold" Canvas.Left="285" Canvas.Top="13"/>
                    <TextBlock Text="30" Foreground="White" FontSize="16" FontWeight="Bold" Canvas.Left="318" Canvas.Top="30"/>
                    <TextBlock Text="45" Foreground="White" FontSize="16" FontWeight="Bold" Canvas.Left="371" Canvas.Top="62"/>
                    <TextBlock Text="60" Foreground="White" FontSize="16" FontWeight="Bold" Canvas.Left="401" Canvas.Top="109"/>
                    <TextBlock Text="90" Foreground="White" FontSize="16" FontWeight="Bold" Canvas.Left="429" Canvas.Top="213"/>
                </Canvas>

                <Canvas x:Name="InnerRotatingCircle" Canvas.Left="75" Canvas.Top="75" Width="300" Height="300" RenderTransformOrigin="0.5,0.5">
                    <Canvas.RenderTransform>
                        <RotateTransform x:Name="RollTransform" Angle="0"/>
                    </Canvas.RenderTransform>

                    <Ellipse Width="300" Height="300" Stroke="Black" StrokeThickness="2" Fill="#1A1A1A"/>

                    <Grid Width="300" Height="300">
                        <Grid.Clip>
                            <EllipseGeometry Center="150,150" RadiusX="148" RadiusY="148"/>
                        </Grid.Clip>

                        <StackPanel Orientation="Vertical">
                            <Rectangle x:Name="SkyRect" Fill="#2196F3" Height="150"/>
                            <Rectangle x:Name="GroundRect" Fill="#5D4037" Height="150"/>
                        </StackPanel>

                        <Canvas Width="300" Height="300">
                            <Line X1="110" Y1="90" X2="190" Y2="90" Stroke="White" StrokeThickness="2" Opacity="0.7"/>
                            <TextBlock Text="20" Foreground="White" FontSize="14" Canvas.Left="85" Canvas.Top="82"/>
                            <TextBlock Text="20" Foreground="White" FontSize="14" Canvas.Left="195" Canvas.Top="82"/>

                            <Line X1="130" Y1="120" X2="170" Y2="120" Stroke="White" StrokeThickness="2" Opacity="0.7"/>
                            <TextBlock Text="10" Foreground="White" FontSize="14" Canvas.Left="105" Canvas.Top="112"/>
                            <TextBlock Text="10" Foreground="White" FontSize="14" Canvas.Left="175" Canvas.Top="112"/>

                            <Line X1="130" Y1="180" X2="170" Y2="180" Stroke="White" StrokeThickness="2" Opacity="0.7"/>
                            <TextBlock Text="10" Foreground="White" FontSize="14" Canvas.Left="105" Canvas.Top="172"/>
                            <TextBlock Text="10" Foreground="White" FontSize="14" Canvas.Left="175" Canvas.Top="172"/>

                            <Line X1="110" Y1="210" X2="190" Y2="210" Stroke="White" StrokeThickness="2" Opacity="0.7"/>
                            <TextBlock Text="20" Foreground="White" FontSize="14" Canvas.Left="85" Canvas.Top="202"/>
                            <TextBlock Text="20" Foreground="White" FontSize="14" Canvas.Left="195" Canvas.Top="202"/>
                        </Canvas>

                        <Canvas Width="300" Height="300">
                            <Rectangle x:Name="HorizonLine" Width="300" Height="3" Fill="White" Canvas.Top="148.5"/>
                        </Canvas>
                    </Grid>

                    <Polygon Points="-10,25 10,25 0,0" Fill="Transparent" Stroke="Orange" StrokeThickness="3" 
                     Canvas.Left="150" Canvas.Top="6"/>

                    <Path Data="M 90,150 L 140,150 L 140,165 M 160,165 L 160,150 L 210,150" 
                  Stroke="Orange" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                </Canvas>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Canvas.Left="147" Canvas.Top="435">
                    <StackPanel Margin="10">
                        <TextBlock Text="ROLL" Foreground="White" HorizontalAlignment="Center" FontSize="12"/>
                        <TextBlock x:Name="RollValueText" Text="0.0°" Foreground="Yellow" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Margin="10">
                        <TextBlock Text="PITCH" Foreground="White" HorizontalAlignment="Center" FontSize="12"/>
                        <TextBlock x:Name="PitchValueText" Text="0.0°" Foreground="Yellow" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Margin="10">
                        <TextBlock Text="YAW" Foreground="White" HorizontalAlignment="Center" FontSize="12"/>
                        <TextBlock x:Name="YawValueText" Text="0.0°" Foreground="Yellow" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

            </Canvas>
        </Viewbox>
    </Grid>
</Page>