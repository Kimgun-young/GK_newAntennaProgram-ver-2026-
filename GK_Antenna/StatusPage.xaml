<Page x:Class="GK_Antenna.StatusPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:GK_Antenna"
      mc:Ignorable="d"
      d:DesignHeight="1080"
      d:DesignWidth="1920"
      Title="StatusPage"
      Background="#2C3E50">

    <Grid HorizontalAlignment="Right"
          VerticalAlignment="Top"
          Margin="0,10,1520,0">

        <TextBlock Text="Connection"
                   Foreground="White"
                   FontSize="24"
                   Margin="128,16,147,177" />

        <Border x:Name="ConnectionBox"
                Width="313"
                Height="189"
                Background="#5A78C9"
                Margin="29,53,48,-17">

            <TextBlock x:Name="ConnectionText"
                       Text="N/A"
                       Foreground="White"
                       FontSize="36"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>

        <Border x:Name="TemperatureBox"
                Width="313"
                Height="189"
                Background="#5A78C9"
                Margin="374,59,-287,-11">

            <TextBlock x:Name="TemperatureText"
                       Text="N/A"
                       Foreground="White"
                       FontSize="36"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>

        <TextBlock Text="Temperature (°C)"
                   Foreground="White"
                   FontSize="24"
                   Margin="437,16,-223,189" />


        <Border x:Name="VoltageBox"
                 Width="313"
                 Height="189"
                 Background="#5A78C9"
                 Margin="722,59,-635,-11">

            <TextBlock x:Name="VoltageText"
                        Text="N/A"
                        Foreground="White"
                        FontSize="36"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
        </Border>

        <TextBlock Text="Voltage (V)"
           Foreground="White"
           FontSize="24"
           Margin="812,16,-544,189" />


        <Border x:Name="CurrentBox"
             Width="313"
             Height="189"
             Background="#5A78C9"
             Margin="1072,59,-986,-11">

            <TextBlock x:Name="CurrentText"
                Text="N/A"
                Foreground="White"
                FontSize="36"
                FontWeight="Bold"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
        </Border>

        <TextBlock Text="Current (A)"
           Foreground="White"
           FontSize="24"
           Margin="1163,16,-895,189" />
    </Grid>
</Page>