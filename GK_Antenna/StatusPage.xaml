<Page x:Class="GK_Antenna.StatusPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      mc:Ignorable="d"
      d:DesignHeight="1080"
      d:DesignWidth="1920"
      Background="#001F3F">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="93*"/>
            <RowDefinition Height="15*"/>
            <RowDefinition Height="932*"/>
        </Grid.RowDefinitions>


        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="15*"/>
            <ColumnDefinition Width="173*"/>
        </Grid.ColumnDefinitions>

        <UniformGrid Rows="1" Columns="5" Margin="0,0,0,20" Grid.RowSpan="3" Grid.ColumnSpan="2">

            <StackPanel Margin="0,83,0,0">
                <TextBlock Text="Connection" Foreground="White" FontSize="36" HorizontalAlignment="Center" FontFamily="/Resources/fonts/#MilSpec33558"/>
                <Border x:Name="ConnectionBox" Height="130" Background="#121212">
                    <TextBlock x:Name="ConnectionText"
                               Text="N/A"
                               Foreground="White"
                               FontFamily="/Resources/fonts/#MilSpec33558"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" FontWeight="Bold"/>
                </Border>
            </StackPanel>

            <StackPanel Margin="-1,78,-2,0">
                <TextBlock Text="Temperature (°C)" Foreground="White" FontSize="36" HorizontalAlignment="Center" FontFamily="/Resources/fonts/#MilSpec33558"/>
                <Border x:Name="TemperatureBox" Height="130" Background="#121212" Margin="5" Width="376">
                    <TextBlock x:Name="TemperatureText"
                               Text="N/A"
                               Foreground="White"
                               FontFamily="/Resources/fonts/#LAB디지털"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" FontWeight="Bold"/>
                </Border>
            </StackPanel>

            <StackPanel Margin="-9,83,-9,0" RenderTransformOrigin="0.5,0.5">
                <TextBlock x:Name="GPS_Label" Text="GPS(Invalid)" Foreground="White" FontSize="36" HorizontalAlignment="Center" FontFamily="/Resources/fonts/#MilSpec33558"/>
                <Border x:Name="GPS_Box" Height="130" Background="#121212" Width="376">
                    <Grid Margin="20,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Latitude (°) :" Width="135" Foreground="#AAAAAA" FontSize="24" FontFamily="/Resources/fonts/#MilSpec33558" VerticalAlignment="Center"/>
                            <TextBlock x:Name="glat" Text="N/A" Foreground="White" FontSize="24" FontFamily="/Resources/fonts/#LAB디지털" Height="22" Width="188"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Longitude (°) :" Width="157" Foreground="#AAAAAA" FontSize="24" FontFamily="/Resources/fonts/#MilSpec33558" VerticalAlignment="Center"/>
                            <TextBlock x:Name="glong" Text="N/A" Foreground="White" FontSize="24" FontFamily="/Resources/fonts/#LAB디지털" RenderTransformOrigin="0.969,0.436" Height="21" Width="171"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Altitude (m) :" Width="146" Foreground="#AAAAAA" FontSize="24" FontFamily="/Resources/fonts/#MilSpec33558" VerticalAlignment="Center"/>
                            <TextBlock x:Name="galt" Text="N/A" Foreground="White" FontSize="24" FontFamily="/Resources/fonts/#LAB디지털" Height="23" Width="187"/>
                        </StackPanel>

                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Margin="3,83,-6,0">
                <TextBlock x:Name="IMU_Label" Text="IMU" Foreground="White" FontSize="36" HorizontalAlignment="Center" FontFamily="/Resources/fonts/#MilSpec33558"/>
                <Border x:Name="IMU_Box" Height="130" Background="#121212" Width="376">
                    <Grid Margin="20,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Pitch (°) :" Width="98" Foreground="#AAAAAA" FontSize="24" FontFamily="/Resources/fonts/#MilSpec33558" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ipitch" Text="N/A" Foreground="White" FontSize="24" FontFamily="/Resources/fonts/#LAB디지털" Height="22" Width="188"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Roll (°) :" Width="88" Foreground="#AAAAAA" FontSize="24" FontFamily="/Resources/fonts/#MilSpec33558" VerticalAlignment="Center"/>
                            <TextBlock x:Name="iroll" Text="N/A" Foreground="White" FontSize="24" FontFamily="/Resources/fonts/#LAB디지털" RenderTransformOrigin="0.969,0.436" Height="21" Width="171"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Heading (°) :" Width="138" Foreground="#AAAAAA" FontSize="24" FontFamily="/Resources/fonts/#MilSpec33558" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ihead" Text="N/A" Foreground="White" FontSize="24" FontFamily="/Resources/fonts/#LAB디지털" Height="23" Width="187"/>
                        </StackPanel>


                    </Grid>
                </Border>
            </StackPanel>

            <!-- EsNo -->
            <StackPanel Margin="11,83,-11,0">
                <TextBlock Text="Es/No (dBm)" Foreground="White" FontSize="36" HorizontalAlignment="Center" FontFamily="/Resources/fonts/#MilSpec33558"/>
                <Border x:Name="EsNoBox" Height="130" Background="#121212" Width="376">
                    <TextBlock x:Name="EsNoText"
                               Text="N/A"
                               Foreground="White"
                               FontFamily="/Resources/fonts/#LAB디지털"
                               FontSize="48"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

        </UniformGrid>

        <Grid Grid.ColumnSpan="2">
            <Grid Margin="20">
                <UniformGrid Rows="1" Columns="5" Margin="0,80,0,0"></UniformGrid>
            </Grid>

            <Canvas VerticalAlignment="Top">
                <Border x:Name="TopBar"
                Background="#001529"
                Height="86"
                Width="1920" 
                Canvas.Left="-20" 
                Canvas.Top="-20"
                MouseEnter="TopBar_MouseEnter"
                MouseLeave="TopBar_MouseLeave" BorderBrush="Black" HorizontalAlignment="Center" VerticalAlignment="Top">
                    <Image Source="/Resources/logos/white_GK_logo.png"
                   Stretch="Uniform"
                   Margin="0,-27,1645,-19"/>
                </Border>

                <TextBlock x:Name="TopBarTrackingDashboard" Text="Tracking Dashboard" Foreground="White" FontSize="48" Canvas.Left="327" IsHitTestVisible="False" Height="64" Width="458" FontFamily="#MilSpec33558" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Top="-9" FontWeight="Bold"/>
                <TextBlock x:Name="TopBarSetting" Text="Setting" Foreground="White" FontSize="48" Canvas.Left="958" Canvas.Top="-9" IsHitTestVisible="False" Height="62" Width="163" FontFamily="#MilSpec33558" HorizontalAlignment="Left" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBlock x:Name="TopBarMap" Text="Map" Foreground="White" FontSize="48" Canvas.Left="1330" Canvas.Top="-9" IsHitTestVisible="False" Height="68" Width="104" HorizontalAlignment="Left" VerticalAlignment="Center" FontFamily="#MilSpec33558" FontWeight="Bold"/>
                <TextBlock x:Name="TopBarMapAbout" Text="About" Foreground="White" FontSize="48" Canvas.Left="1661" Canvas.Top="-9" IsHitTestVisible="False" Height="68" Width="146" FontFamily="#MilSpec33558" HorizontalAlignment="Left" VerticalAlignment="Center" FontWeight="Bold"/>

                <Border x:Name="DropBar"
                    Background="White"
                    Height="173"
                    Width="1920"
                    Canvas.Left="-20"
                    Canvas.Top="66" 
                    Visibility="Collapsed"
                    MouseEnter="DropBar_MouseEnter"
                    MouseLeave="DropBar_MouseLeave" HorizontalAlignment="Center" VerticalAlignment="Center">

                    <Canvas>
                        <TextBlock x:Name="StatusText"  Text="• Status" Foreground="Black" FontSize="36" Cursor="Hand" MouseLeftButtonDown="StatusText_Click" Width="148" Canvas.Left="342" Canvas.Top="22" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontFamily="#MilSpec33558"/>

                        <TextBlock x:Name="BeamSettingText" Text="• Beam Setting" Foreground="Black" FontSize="36" Cursor="Hand" MouseLeftButtonDown="BeamSettingText_Click" Canvas.Left="944" Canvas.Top="22" RenderTransformOrigin="0.44,0.606" HorizontalAlignment="Left" VerticalAlignment="Center" FontWeight="Bold" FontFamily="#MilSpec33558"/>
                        <TextBlock x:Name="IP_SettingText" Text="• IP Setting" Foreground="Black" FontSize="36" Cursor="Hand" MouseLeftButtonDown="IP_SettingText_Click" Canvas.Left="944" Canvas.Top="86" HorizontalAlignment="Left" VerticalAlignment="Center" FontWeight="Bold" FontFamily="#MilSpec33558"/>

                        <TextBlock Text="• Map" Foreground="Black" FontSize="36" Cursor="Hand" MouseLeftButtonDown="MapText_Click" Canvas.Left="1334" Canvas.Top="22" HorizontalAlignment="Left" VerticalAlignment="Center" FontWeight="Bold" FontFamily="#MilSpec33558" Width="111"/>


                        <TextBlock Text="• Company Info" Foreground="Black" FontSize="36" Cursor="Hand" MouseLeftButtonDown="CompanyInfoText_Click" Canvas.Left="1639" Canvas.Top="22" HorizontalAlignment="Left" VerticalAlignment="Center" FontWeight="Bold" FontFamily="#MilSpec33558"/>
                    </Canvas>
                </Border>
            </Canvas>
        </Grid>

        <Canvas x:Name="CompassCanvas"
                Width="350"
                Height="314"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="440,208,0,0" Grid.Row="2" Grid.Column="1" Background="#001F3F"/>

        <TextBlock x:Name="AzimuthText"
