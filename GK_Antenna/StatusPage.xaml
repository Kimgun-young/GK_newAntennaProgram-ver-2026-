                <Line X1="0" Y1="0" X2="15" Y2="0" Stroke="White" StrokeThickness="2"/>
                <TextBlock Text="80" Foreground="White" FontSize="11" FontWeight="Bold" Canvas.Left="20" Canvas.Top="-7"/>
