                <Line X1="0" Y1="150" X2="15" Y2="150" Stroke="White" StrokeThickness="2"/>
                <TextBlock Text="20" Foreground="White" FontSize="11" FontWeight="Bold" Canvas.Left="20" Canvas.Top="143"/>
                <Line X1="0" Y1="175" X2="8" Y2="175" Stroke="White" StrokeThickness="1"/>

                <Line X1="0" Y1="200" X2="20" Y2="200" Stroke="White" StrokeThickness="2.5"/>
                <TextBlock Text="0" Foreground="White" FontSize="11" FontWeight="Bold" Canvas.Left="25" Canvas.Top="193"/>
                <Line X1="0" Y1="225" X2="8" Y2="225" Stroke="White" StrokeThickness="1"/>

                <Line X1="0" Y1="250" X2="15" Y2="250" Stroke="White" StrokeThickness="2"/>
                <TextBlock Text="-20" Foreground="White" FontSize="11" FontWeight="Bold" Canvas.Left="20" Canvas.Top="243"/>
