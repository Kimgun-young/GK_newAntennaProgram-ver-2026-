                <TextBlock Text="PITCH" Foreground="White" FontSize="24"
           Canvas.Left="198" Canvas.Top="431"/>

                <!-- YAW 레이블 -->
                <TextBlock Text="YAW" Foreground="White" FontSize="24"
           Canvas.Left="351" Canvas.Top="431" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                <!-- ROLL 값 -->
